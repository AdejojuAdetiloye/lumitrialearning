datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PARENT
  ADMIN
  MANAGER
  INSTRUCTOR
}

enum ParentSalutation {
  MR
  MRS
  MS
  MX
}

enum AgeTier {
  ROOKIES
  EXPLORERS
  ASCENT
  VETERAN
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  role         Role           @default(PARENT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  parentProfile ParentProfile?
  staffProfile  StaffProfile?
  payments     Payment[]
  instructorAssignments InstructorAssignment[] @relation("InstructorUser")
}

model ParentProfile {
  id          String            @id @default(cuid())
  userId      String            @unique
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  salutation  ParentSalutation @default(MR)
  firstName   String
  lastName    String
  phone       String?
  country     String
  createdAt   DateTime          @default(now())
  children    Child[]
}

/// Display name for MANAGER / INSTRUCTOR (no parent profile).
model StaffProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Child {
  id             String             @id @default(cuid())
  parentId       String
  parent         ParentProfile      @relation(fields: [parentId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  birthDate      DateTime?
  subscriptions  Subscription[]
  timetable      TimetableEntry[]
  paymentLines   PaymentLine[]
  instructorAssignments InstructorAssignment[]
}

/// Many instructors per child per program (course). Assigned by ADMIN or MANAGER.
model InstructorAssignment {
  id            String   @id @default(cuid())
  childId       String
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructorId  String
  instructor    User     @relation("InstructorUser", fields: [instructorId], references: [id], onDelete: Cascade)
  assignedAt    DateTime @default(now())

  @@unique([childId, courseId, instructorId])
}

model Course {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String?
  subscriptions Subscription[]
  paymentLines  PaymentLine[]
  instructorAssignments InstructorAssignment[]
}

/// Authoritative tier prices per country (amounts match business rules)
model TierPrice {
  id       String  @id @default(cuid())
  country  String
  tier     AgeTier
  amount   Decimal @db.Decimal(12, 2)
  currency String

  @@unique([country, tier])
}

model Payment {
  id              String        @id @default(cuid())
  parentUserId    String
  user            User          @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  paypalOrderId   String?
  paypalCaptureId String?
  status          PaymentStatus @default(PENDING)
  totalAmount     Decimal       @db.Decimal(12, 2)
  currency        String
  rawPayload      Json?
  createdAt       DateTime      @default(now())
  lines           PaymentLine[]
}

model PaymentLine {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  childId   String
  child     Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id])
  tier      AgeTier
  amount    Decimal @db.Decimal(12, 2)
}

model Subscription {
  id                 String             @id @default(cuid())
  childId            String
  child              Child              @relation(fields: [childId], references: [id], onDelete: Cascade)
  courseId           String
  course             Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tier               AgeTier
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  amount             Decimal            @db.Decimal(12, 2)
  currency           String
  lastPaymentAt      DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([childId, courseId])
}

model TimetableEntry {
  id          String   @id @default(cuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  title       String
  startsAt    DateTime
  endsAt      DateTime
  meetingLink String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
