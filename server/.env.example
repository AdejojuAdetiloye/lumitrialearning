# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lumetra?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"

# API
PORT=4000
CORS_ORIGINS="http://localhost:8080,http://127.0.0.1:8080"

# Flutterwave (Standard hosted checkout — secret key from dashboard; use test keys in sandbox)
FLUTTERWAVE_SECRET_KEY=""
# Dashboard → Settings → Webhooks: secret hash (HMAC). Required in production for POST /api/checkout/flutterwave-webhook
FLUTTERWAVE_SECRET_HASH=""
# Optional: title shown on Flutterwave checkout page
# FLUTTERWAVE_CHECKOUT_TITLE="Lumetra Learning"

# First admin user (used by prisma seed)
ADMIN_EMAIL="admin@lumitrialearning.org"
ADMIN_PASSWORD="ChangeMeAdmin123!"
# Optional display name for admin in dashboards (StaffProfile)
ADMIN_FIRST_NAME=""
ADMIN_LAST_NAME=""

# Optional demo parent (created/updated by prisma seed when both are set)
SEED_PARENT_EMAIL=""
SEED_PARENT_PASSWORD=""
